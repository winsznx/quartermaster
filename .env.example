# Per MASTER_PRD.md §23.1 — required env vars.
# Copy to `.env` and fill in real values for local development. NEVER commit `.env`.
# WARNING: never paste private keys into Claude Code (or any AI assistant) chat context.

# --- Zerion API ---
# Read access to Zerion API (or use --x402 mode for per-call payments).
ZERION_API_KEY=

# Required if using --x402 mode. The QM wallet's private key.
# This wallet must be FRESH — never the principal's main wallet.
WALLET_PRIVATE_KEY=

# Auto-populated by `zerion wallet create --agent`. Stored at ~/.zerion/config.json by upstream.
ZERION_AGENT_TOKEN=

# --- QM daemon runtime ---
QM_TICK_SECONDS=60
QM_BRIDGE_TIMEOUT_SEC=120
QM_SWAP_TIMEOUT_SEC=90
QM_DASHBOARD_PORT=7402

# Environment: "mainnet" | "testnet"
QM_ENV=testnet

# Log level: "debug" | "info" | "warn" | "error"
QM_LOG_LEVEL=info
