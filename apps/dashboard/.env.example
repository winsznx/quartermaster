# Quartermaster dashboard — environment variables
#
# Copy to `.env.local` for local development. NEVER commit `.env.local` (it's
# gitignored at the repo root). Vercel reads these from project settings, not
# from this file.

# Base URL for the QM daemon HTTP API (PRD §22.3).
#
# - Self-host (production users running their own daemon on the same machine
#   as the dashboard): leave unset; the dashboard falls back to
#   http://127.0.0.1:7402 automatically.
# - Vercel-hosted demo: point at the Railway-deployed demo daemon, e.g.:
#     NEXT_PUBLIC_DAEMON_URL=https://qm-daemon.up.railway.app
#
# `NEXT_PUBLIC_` prefix is required so Next.js inlines the value at build time
# for client components.
NEXT_PUBLIC_DAEMON_URL=http://127.0.0.1:7402
