{
  "name": "quartermaster",
  "private": true,
  "version": "0.0.0",
  "description": "Treasury layer for the agent economy. Built on Zerion CLI.",
  "packageManager": "pnpm@9.15.5",
  "scripts": {
    "dev:landing": "pnpm --filter landing dev",
    "dev:dashboard": "pnpm --filter dashboard dev",
